# API配置
ANTHROPIC_API_KEY=your_api_key_here
BASE_URL=https://api.minimaxi.com/anthropic

# 文件与列配置
INPUT_FILE=your_input_file.xlsx
OUTPUT_FILE=your_output_file.xlsx
SOURCE_COLUMN=F
TARGET_COLUMN=I

# 模型配置
MODEL_NAME=MiniMax-M2.7
MAX_TOKENS=4096

# 批处理配置
BATCH_SIZE=20
MAX_WORKERS=3
REQUEST_TIMEOUT=120
RETRY_TIMES=3
RETRY_DELAY=2
FINAL_RETRY_ROUNDS=1
